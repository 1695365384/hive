{
  "name": "@hive/openclaw-adapter",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "RUN_INTEGRATION_TESTS=true vitest run tests/integration.test.ts",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@hive/orchestrator": "workspace:*"
  },
  "peerDependencies": {
    "openclaw": ">=2026.0.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@larksuite/openclaw-lark": "2026.3.25",
    "@types/node": "^20.11.0",
    "openclaw": "2026.3.23-2",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  }
}
