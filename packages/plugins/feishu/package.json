{
  "name": "@bundy-lmw/hive-plugin-feishu",
  "version": "1.0.11",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "hive": {
    "plugin": true,
    "entry": "dist/index.js",
    "id": "feishu"
  },
  "keywords": [
    "hive-plugin",
    "feishu",
    "lark",
    "hive",
    "agent",
    "bot"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:zip": "node scripts/build-zip.mjs",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@bundy-lmw/hive-core": "workspace:*",
    "@larksuiteoapi/node-sdk": "^1.59.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "config.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1695365384/hive.git",
    "directory": "packages/plugins/feishu"
  },
  "homepage": "https://github.com/1695365384/hive#readme",
  "license": "MIT"
}
