{
  "name": "@aiclaw/service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "node-service": "./dist/service.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.scripts.json && tsx build.ts",
    "build:exe": "pnpm build && pkg dist/service.js --config pkg.config.json --targets node18-macos-arm64,node18-macos-x64,node18-win-x64,node18-linux-x64 --output ../app/src-tauri/binaries/node-service",
    "dev": "tsc --project tsconfig.scripts.json --watch",
    "start": "node dist/index.js",
    "start:dev": "tsx src/index.ts",
    "start:ws": "tsx src/index.ts --ws",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aiclaw/core": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.24.0",
    "pkg": "^5.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
