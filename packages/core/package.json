{
  "name": "@bundy-lmw/hive-core",
  "version": "1.0.10",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./runner": {
      "import": "./dist/agents/core/runner.js",
      "types": "./dist/agents/core/runner.d.ts"
    },
    "./providers": {
      "import": "./dist/providers/index.js",
      "types": "./dist/providers/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && npm run copy-templates",
    "copy-templates": "cp -r src/agents/prompts/templates dist/agents/prompts/",
    "dev": "tsc -p tsconfig.build.json --watch",
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.62",
    "@ai-sdk/deepseek": "^2.0.26",
    "@ai-sdk/google": "^3.0.51",
    "@ai-sdk/mistral": "^3.0.27",
    "@ai-sdk/openai": "^3.0.46",
    "@ai-sdk/openai-compatible": "^2.0.37",
    "@ai-sdk/provider": "^3.0.8",
    "@ai-sdk/xai": "^3.0.74",
    "ai": "^6.0.129",
    "better-sqlite3": "^11.0.0",
    "cheerio": "^1.2.0",
    "conf": "^13.0.1",
    "node-cron": "^4.2.1",
    "turndown": "^7.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cheerio": "^1.0.0",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1695365384/hive.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/1695365384/hive#readme",
  "license": "MIT"
}
