{
  "name": "@bundy-lmw/hive-core",
  "version": "1.0.24",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./providers": {
      "import": "./dist/providers/index.js",
      "types": "./dist/providers/index.d.ts"
    },
    "./vertical": {
      "import": "./dist/vertical/index.js",
      "types": "./dist/vertical/index.d.ts"
    },
    "./routing": {
      "import": "./dist/routing/index.js",
      "types": "./dist/routing/index.d.ts"
    }
  },
  "bin": {
    "hive-pack": "./dist/cli/pack-cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && npm run copy-templates",
    "copy-templates": "node ../../scripts/copy-templates.mjs",
    "dev": "tsc -p tsconfig.build.json --watch",
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true});require('fs').rmSync('coverage',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@cjhyy/code-shell-core": "0.5.0-rc.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@oh-my-pi/pi-ai": "17.0.6",
    "@oh-my-pi/pi-catalog": "17.0.6",
    "@oh-my-pi/pi-coding-agent": "17.0.6",
    "@opencode-ai/sdk": "^1.17.17",
    "ai": "^6.0.129",
    "better-sqlite3": "^11.0.0",
    "cheerio": "^1.2.0",
    "conf": "^13.0.1",
    "node-cron": "^4.2.1",
    "tiktoken": "^1.0.22",
    "turndown": "^7.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cheerio": "^1.0.0",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1695365384/hive.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/1695365384/hive#readme",
  "license": "MIT"
}
