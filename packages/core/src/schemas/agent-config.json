{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hive.dev/schemas/agent-config.json",
  "title": "Hive Agent Configuration",
  "description": "Hive SDK Agent 配置，由外部应用传入",
  "type": "object",
  "properties": {
    "providers": {
      "type": "array",
      "description": "Provider 配置列表",
      "items": {
        "$ref": "./provider-config.json"
      },
      "minItems": 0
    },
    "activeProvider": {
      "type": "string",
      "description": "当前激活的 Provider ID，不指定则使用第一个或从环境变量检测"
    },
    "mcpServers": {
      "type": "object",
      "description": "MCP 服务器配置",
      "additionalProperties": {
        "$ref": "#/definitions/McpServerConfig"
      }
    },
    "defaults": {
      "$ref": "#/definitions/AgentDefaults"
    }
  },
  "required": [],
  "definitions": {
    "McpServerConfig": {
      "type": "object",
      "properties": {
        "command": {
          "type": "string",
          "description": "启动命令",
          "examples": ["npx", "node", "python"]
        },
        "args": {
          "type": "array",
          "description": "命令参数",
          "items": {
            "type": "string"
          }
        },
        "env": {
          "type": "object",
          "description": "环境变量",
          "additionalProperties": {
            "type": "string"
          }
        },
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "是否启用"
        },
        "description": {
          "type": "string",
          "description": "服务器描述"
        }
      },
      "required": ["command"]
    },
    "AgentDefaults": {
      "type": "object",
      "properties": {
        "model": {
          "type": "string",
          "description": "默认模型（覆盖 Provider 设置）"
        },
        "maxTurns": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 20,
          "description": "最大对话轮次"
        },
        "thoroughness": {
          "type": "string",
          "enum": ["quick", "medium", "very-thorough"],
          "default": "medium",
          "description": "探索彻底程度"
        },
        "timeout": {
          "type": "integer",
          "minimum": 1000,
          "description": "单次请求超时（毫秒）"
        },
        "streaming": {
          "type": "boolean",
          "default": true,
          "description": "是否启用流式输出"
        }
      }
    }
  }
}
