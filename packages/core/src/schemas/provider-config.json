{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hive.dev/schemas/provider-config.json",
  "title": "Provider Configuration",
  "description": "单个 Provider 配置",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "唯一标识符，用于切换和引用",
      "examples": ["glm", "deepseek", "openai", "anthropic"]
    },
    "name": {
      "type": "string",
      "description": "显示名称",
      "examples": ["GLM (智谱)", "DeepSeek", "OpenAI"]
    },
    "type": {
      "type": "string",
      "enum": ["openai", "anthropic", "google", "openai-compatible"],
      "default": "openai-compatible",
      "description": "Provider 类型，决定使用哪个适配器"
    },
    "baseUrl": {
      "type": "string",
      "format": "uri",
      "description": "API 基础 URL"
    },
    "apiKey": {
      "type": "string",
      "description": "API Key，可省略（从环境变量读取）"
    },
    "apiKeyEnv": {
      "type": "string",
      "description": "API Key 环境变量名，apiKey 为空时使用",
      "default": "${ID}_API_KEY",
      "examples": ["GLM_API_KEY", "DEEPSEEK_API_KEY"]
    },
    "model": {
      "type": "string",
      "description": "默认模型",
      "examples": ["glm-5", "deepseek-chat", "gpt-4o"]
    },
    "models": {
      "type": "array",
      "description": "可用模型列表（可选，用于 UI 展示）",
      "items": {
        "$ref": "#/definitions/ModelSpec"
      }
    },
    "enabled": {
      "type": "boolean",
      "default": true,
      "description": "是否启用"
    },
    "description": {
      "type": "string",
      "description": "描述信息"
    },
    "extra": {
      "type": "object",
      "description": "额外配置（透传给适配器）",
      "additionalProperties": true
    }
  },
  "required": ["id", "baseUrl"],
  "additionalProperties": false,
  "definitions": {
    "ModelSpec": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "模型 ID"
        },
        "name": {
          "type": "string",
          "description": "显示名称"
        },
        "contextWindow": {
          "type": "integer",
          "description": "上下文窗口大小（tokens）"
        },
        "maxOutputTokens": {
          "type": "integer",
          "description": "最大输出 tokens"
        },
        "supportsVision": {
          "type": "boolean",
          "description": "是否支持视觉"
        },
        "supportsTools": {
          "type": "boolean",
          "default": true,
          "description": "是否支持工具调用"
        },
        "supportsStreaming": {
          "type": "boolean",
          "default": true,
          "description": "是否支持流式输出"
        },
        "pricing": {
          "type": "object",
          "properties": {
            "input": {
              "type": "number",
              "description": "输入价格/百万 tokens"
            },
            "output": {
              "type": "number",
              "description": "输出价格/百万 tokens"
            },
            "currency": {
              "type": "string",
              "enum": ["USD", "CNY"]
            }
          }
        }
      },
      "required": ["id"]
    }
  }
}
