# Hive Server Configuration
#
# This file is for sensitive environment variables only.
# Most configuration should go in hive.config.json
#
# Usage: Copy to .env and fill in your values
#   cp .env.example .env

# ===========================================
# LLM Provider API Keys
# ===========================================

# GLM (智谱 AI)
GLM_API_KEY=your-glm-api-key

# Anthropic (Claude)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI
# OPENAI_API_KEY=your-openai-api-key

# DeepSeek
# DEEPSEEK_API_KEY=your-deepseek-api-key

# ===========================================
# Plugin Secrets
# ===========================================

# Feishu Plugin (@hive/plugin-feishu)
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_ENCRYPT_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
