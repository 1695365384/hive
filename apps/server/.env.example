# Hive Server Configuration
#
# This file is for sensitive environment variables only.
# Most configuration should go in hive.config.json
#
# Usage: Copy to .env and fill in your values
#   cp .env.example .env

# ===========================================
# LLM Provider API Keys
# ===========================================

# GLM (智谱 AI)
GLM_API_KEY=your-glm-api-key

# Anthropic (Claude)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI
# OPENAI_API_KEY=your-openai-api-key

# DeepSeek
# DEEPSEEK_API_KEY=your-deepseek-api-key

# ===========================================
# Plugin Secrets
# ===========================================

# Feishu Plugin (@hive/plugin-feishu) - 仅需 App ID 和 Secret
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# FEISHU_ENCRYPT_KEY=xxx      # 可选：用于签名验证
# FEISHU_VERIFICATION_TOKEN=xxx  # 可选：用于签名验证

# ===========================================
# Heartbeat
# ===========================================
# HEARTBEAT_ENABLED=true        # 启用心跳调度
# HEARTBEAT_INTERVAL_MS=300000  # 心跳间隔（毫秒），默认 5 分钟
# HEARTBEAT_MODEL=             # 心跳检查使用的模型（可选）
# HEARTBEAT_PROMPT=            # 自定义心跳 prompt（可选，默认读取 HEARTBEAT.md）
