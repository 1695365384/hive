{
  "name": "@bundy-lmw/hive-server",
  "version": "1.0.7",
  "type": "module",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "bin": {
    "hive": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "types": "./dist/main.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').copyFileSync('mcp-catalog.json','dist/mcp-catalog.json')\"",
    "dev": "tsc -p tsconfig.build.json --watch",
    "start": "bun dist/main.js",
    "cli": "bun dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "sea:build": "node -e \"console.error('SEA bundling is unsupported; agent kernel is pi \u2014 use Bun start');process.exit(1)\""
  },
  "dependencies": {
    "@bundy-lmw/hive-core": "workspace:*",
    "@officecli/officecli": "^1.0.132",
    "commander": "^14.0.3",
    "dotenv": "^16.4.0",
    "hono": "^4.12.0",
    "pino": "^10.3.1",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.18.1",
    "ajv": "^8.18.0",
    "esbuild": "^0.25.0",
    "postject": "^1.0.0-alpha.6",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist",
    "mcp-catalog.json",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1695365384/hive.git",
    "directory": "apps/server"
  },
  "homepage": "https://github.com/1695365384/hive#readme",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.3.14"
  }
}
