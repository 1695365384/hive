{
  "name": "@hive/server",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "bin": {
    "hive": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "types": "./dist/main.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "start": "node dist/main.js",
    "cli": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hive/core": "workspace:*",
    "@hive/orchestrator": "workspace:*",
    "@hive/plugin-feishu": "workspace:*",
    "dotenv": "^16.4.0",
    "hono": "^4.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "ajv": "^8.18.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
