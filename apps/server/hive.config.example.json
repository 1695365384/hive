{
  "$schema": "./hive.config.schema.json",

  "server": {
    "port": 3000,
    "host": "127.0.0.1",
    "logLevel": "info"
  },

  "provider": {
    "id": "glm",
    "apiKey": "${GLM_API_KEY}",
    "model": "glm-4"
  },

  "plugins": {
    "@larksuite/openclaw-lark": {
      "channels": {
        "feishu": {
          "appId": "${FEISHU_APP_ID}",
          "appSecret": "${FEISHU_APP_SECRET}",
          "domain": "feishu"
        }
      }
    }
  }
}
